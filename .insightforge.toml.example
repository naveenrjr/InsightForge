[policy]
min_confidence = 0.65
require_sources = false
fail_on_stderr = true
block_absolute_language = false
max_output_chars = 20000

[redaction]
enabled = true
mask = "[REDACTED]"
patterns = [
  "sk-[A-Za-z0-9_\\-]+",
  "AIza[0-9A-Za-z\\-_]+",
  "ghp_[A-Za-z0-9]+",
  "\\b[\\w.\\-]+@[\\w.\\-]+\\.\\w+\\b",
  "Bearer\\s+[A-Za-z0-9\\-._~+/]+=*",
]

[storage]
sqlite_path = ".insightforge/traces.db"
